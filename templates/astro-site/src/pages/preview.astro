---
export const prerender = false

import SEOLayout from '../layouts/SEOLayout.astro'
import LivePreview from '../components/LivePreview'
import { payload } from '../lib/payload'

const url = new URL(Astro.request.url)
const collection = url.searchParams.get('collection')
const slug = url.searchParams.get('slug')
const token = url.searchParams.get('token')

const previewSecret = import.meta.env.PREVIEW_SECRET
if (!previewSecret || token !== previewSecret) {
  return new Response('Unauthorized', { status: 401 })
}

if (!collection || !slug) {
  return new Response('Missing collection or slug', { status: 400 })
}

const doc = await payload.fetchBySlug(collection, slug, 2, true)

if (!doc) {
  return new Response('Document not found', { status: 404 })
}

const serverURL = import.meta.env.PAYLOAD_API_URL?.replace(/\/api\/?$/, '') || ''
---

<SEOLayout title={`[PREVIEW] ${(doc as any).title || (doc as any).name || slug}`} noindex={true}>
  <div class="bg-yellow-100 border-b border-yellow-300 px-4 py-2 text-center text-sm font-medium text-yellow-800">
    Preview Mode -- Editing in real-time
  </div>
  <LivePreview client:load initialData={doc} serverURL={serverURL} />
</SEOLayout>
