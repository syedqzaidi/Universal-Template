---
interface Props {
  placeholder?: string
}

const { placeholder = 'Search FAQs...' } = Astro.props
---

<div class="relative mb-8">
  <input
    type="search"
    placeholder={placeholder}
    class="w-full px-4 py-3 rounded-lg border bg-background text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary"
    data-faq-search
    aria-label="Search frequently asked questions"
  />
  <div class="hidden text-center py-8 text-muted-foreground" data-faq-empty>
    No matching questions found.
  </div>
</div>

<script>
  function initFaqSearch() {
    const input = document.querySelector('[data-faq-search]') as HTMLInputElement
    const empty = document.querySelector('[data-faq-empty]') as HTMLElement
    if (!input) return

    let timeout: ReturnType<typeof setTimeout>

    input.addEventListener('input', () => {
      clearTimeout(timeout)
      timeout = setTimeout(() => {
        const query = input.value.toLowerCase().trim()
        const items = document.querySelectorAll('[data-faq-item]')
        let visible = 0

        items.forEach((item) => {
          const el = item as HTMLElement
          const text = el.textContent?.toLowerCase() || ''
          const matches = !query || text.includes(query)
          el.style.display = matches ? '' : 'none'
          if (matches) visible++
        })

        if (empty) {
          empty.classList.toggle('hidden', visible > 0 || !query)
        }
      }, 300)
    })
  }

  initFaqSearch()
  document.addEventListener('astro:page-load', initFaqSearch)
</script>
