---
interface Props {
  headings: { depth: number; slug: string; text: string }[]
}

const { headings } = Astro.props
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3)
---

{tocHeadings.length > 0 && (
  <>
    {/* Desktop: sticky sidebar */}
    <nav aria-label="Table of contents" class="hidden lg:block sticky top-24">
      <p class="font-semibold text-sm mb-3">On this page</p>
      <ul class="space-y-2 text-sm border-l">
        {tocHeadings.map((heading) => (
          <li>
            <a
              href={`#${heading.slug}`}
              class:list={[
                'block border-l-2 -ml-px transition-colors hover:text-foreground hover:border-primary',
                heading.depth === 2 ? 'pl-4 text-muted-foreground' : 'pl-8 text-muted-foreground/80',
              ]}
              data-toc-link={heading.slug}
            >
              {heading.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    {/* Mobile: collapsible */}
    <details class="lg:hidden mb-8 rounded-lg border p-4">
      <summary class="font-semibold text-sm cursor-pointer">Table of Contents</summary>
      <ul class="mt-3 space-y-2 text-sm">
        {tocHeadings.map((heading) => (
          <li>
            <a
              href={`#${heading.slug}`}
              class:list={[
                'block hover:text-primary transition-colors',
                heading.depth === 3 ? 'pl-4' : '',
              ]}
            >
              {heading.text}
            </a>
          </li>
        ))}
      </ul>
    </details>

    <script>
      function initToC() {
        const links = document.querySelectorAll('[data-toc-link]')
        if (!links.length) return

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                links.forEach((link) => {
                  const el = link as HTMLElement
                  if (el.dataset.tocLink === entry.target.id) {
                    el.classList.add('text-foreground', 'border-primary')
                    el.classList.remove('text-muted-foreground', 'border-transparent')
                    el.setAttribute('aria-current', 'true')
                  } else {
                    el.classList.remove('text-foreground', 'border-primary')
                    el.classList.add('text-muted-foreground', 'border-transparent')
                    el.removeAttribute('aria-current')
                  }
                })
              }
            })
          },
          { rootMargin: '-80px 0px -80% 0px', threshold: 0 }
        )

        document.querySelectorAll('h2[id], h3[id]').forEach((h) => observer.observe(h))
      }

      initToC()
      document.addEventListener('astro:page-load', initToC)
    </script>
  </>
)}
