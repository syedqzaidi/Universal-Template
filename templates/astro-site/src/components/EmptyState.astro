---
interface Props {
  heading?: string
  message?: string
  ctaText?: string
  ctaHref?: string
}

const {
  heading = 'Nothing here yet',
  message = 'Check back soon for new content.',
  ctaText,
  ctaHref,
} = Astro.props
---

<div class="text-center py-16 px-4">
  <svg class="mx-auto mb-6 text-muted-foreground/50" xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="12" cy="12" r="10"/>
    <path d="M16 16s-1.5-2-4-2-4 2-4 2"/>
    <line x1="9" x2="9.01" y1="9" y2="9"/>
    <line x1="15" x2="15.01" y1="9" y2="9"/>
  </svg>
  <h2 class="text-xl font-semibold mb-2">{heading}</h2>
  <p class="text-muted-foreground max-w-md mx-auto mb-6">{message}</p>
  {ctaText && ctaHref && (
    <a
      href={ctaHref}
      class="inline-flex items-center px-6 py-3 rounded-lg bg-primary text-primary-foreground font-medium hover:bg-primary/90 transition-colors"
    >
      {ctaText}
    </a>
  )}
</div>
