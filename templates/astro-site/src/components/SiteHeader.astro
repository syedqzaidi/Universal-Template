---
// src/components/SiteHeader.astro
import { payload } from '../lib/payload'
import { primaryNav } from '../lib/nav-config'

// Fetch dynamic children for nav items that have a dynamic config
let dynamicData: Record<string, any[]> = {}
let siteSettings: any = { siteName: 'Site' }

try {
  const collectionFetchers: Record<string, (params?: Record<string, string>) => Promise<{ docs: any[] }>> = {
    'services': (p) => payload.getAllServices(p),
    'locations': (p) => payload.getAllLocations(p),
    'blog-posts': (p) => payload.getAllBlogPosts(p),
    'pages': (p) => payload.getAllPages(p),
  }

  await Promise.all(
    primaryNav
      .filter((item) => item.dynamic)
      .map(async (item) => {
        const { collection } = item.dynamic!
        const fetcher = collectionFetchers[collection]
        if (fetcher) {
          const { docs } = await fetcher({ sort: item.dynamic!.labelField })
          dynamicData[collection] = docs
        }
      }),
  )

  siteSettings = await payload.getSiteSettings()
} catch {
  // Payload unavailable — render with fallback empty data
}
---

<header class="sticky top-0 z-50 w-full border-b bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/60">
  <nav aria-label="Main navigation" class="container flex h-16 items-center justify-between">
    <a href="/" class="flex items-center gap-2 font-bold text-xl">
      {typeof siteSettings.logo === 'object' && siteSettings.logo?.url && (
        <img src={siteSettings.logo.url} alt={siteSettings.siteName} class="h-8 w-auto" />
      )}
      <span>{siteSettings.siteName}</span>
    </a>

    <!-- Mobile menu toggle -->
    <button
      class="md:hidden p-2 rounded-lg hover:bg-muted transition-colors"
      aria-label="Toggle menu"
      aria-expanded="false"
      data-mobile-toggle
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
    </button>

    <div class="hidden md:flex items-center gap-6">
      {primaryNav.map((item) => {
        const dynamicDocs = item.dynamic ? dynamicData[item.dynamic.collection] : null
        return dynamicDocs ? (
          <div class="relative group">
            <a href={item.href} class="font-medium hover:text-primary transition-colors" aria-haspopup="true">{item.label}</a>
            <div class="absolute top-full left-0 pt-2 hidden group-hover:block group-focus-within:block">
              <ul class="bg-background border rounded-lg shadow-lg p-2 min-w-48">
                {dynamicDocs.map((doc) => (
                  <li>
                    <a href={`${item.dynamic!.pathPrefix}/${doc.slug}`} class="block px-4 py-2 rounded hover:bg-muted transition-colors">
                      {doc[item.dynamic!.labelField]}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ) : (
          <a href={item.href} class="font-medium hover:text-primary transition-colors">{item.label}</a>
        )
      })}

      {siteSettings.phone && (
        <a href={`tel:${siteSettings.phone}`} class="font-semibold text-primary">
          {siteSettings.phone}
        </a>
      )}
    </div>
  </nav>

  <!-- Mobile menu (hidden by default, toggled via JS) -->
  <div class="hidden md:hidden border-t" data-mobile-menu>
    <div class="container py-4 space-y-3">
      {primaryNav.map((item) => {
        const dynamicDocs = item.dynamic ? dynamicData[item.dynamic.collection] : null
        return (
          <>
            <a href={item.href} class="block font-medium py-2 hover:text-primary">{item.label}</a>
            {dynamicDocs && dynamicDocs.map((doc) => (
              <a href={`${item.dynamic!.pathPrefix}/${doc.slug}`} class="block pl-4 py-1 text-sm text-muted-foreground hover:text-foreground">{doc[item.dynamic!.labelField]}</a>
            ))}
          </>
        )
      })}
      {siteSettings.phone && (
        <a href={`tel:${siteSettings.phone}`} class="block font-semibold text-primary py-2">{siteSettings.phone}</a>
      )}
    </div>
  </div>
</header>

<script>
  const toggle = document.querySelector('[data-mobile-toggle]')
  const menu = document.querySelector('[data-mobile-menu]')
  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true'
    toggle.setAttribute('aria-expanded', String(!expanded))
    menu?.classList.toggle('hidden')
  })
</script>
