---
// src/components/SiteFooter.astro
import { payload } from '../lib/payload'
import { footerSections } from '../lib/nav-config'

// Fetch dynamic data for footer sections that need it
let resolvedSections: any[] = footerSections.map((section) => ({ ...section, resolvedLinks: section.links || [] }))
let siteSettings: any = { siteName: 'Site' }
const currentYear = new Date().getFullYear()

try {
  const collectionFetchers: Record<string, (params?: Record<string, string>) => Promise<{ docs: any[] }>> = {
    'services': (p) => payload.getAllServices(p),
    'locations': (p) => payload.getAllLocations(p),
    'blog-posts': (p) => payload.getAllBlogPosts(p),
    'pages': (p) => payload.getAllPages(p),
  }

  resolvedSections = await Promise.all(
    footerSections.map(async (section) => {
      if (section.dynamic) {
        const fetcher = collectionFetchers[section.dynamic.collection]
        if (fetcher) {
          const params: Record<string, string> = {
            sort: section.dynamic.labelField,
          }
          if (section.dynamic.limit) {
            params.limit = String(section.dynamic.limit)
          }
          const { docs } = await fetcher(params)
          return {
            ...section,
            resolvedLinks: docs.map((doc) => ({
              label: doc[section.dynamic!.labelField],
              href: `${section.dynamic!.pathPrefix}/${doc.slug}`,
            })),
          }
        }
      }
      return { ...section, resolvedLinks: section.links || [] }
    }),
  )

  siteSettings = await payload.getSiteSettings()
} catch {
  // Payload unavailable — render with fallback empty data
}
---

<footer class="border-t bg-muted/50 mt-auto">
  <div class="container py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <!-- Brand and contact -->
      <div>
        <p class="font-bold text-lg">{siteSettings.siteName}</p>
        {siteSettings.tagline && <p class="text-muted-foreground mt-1">{siteSettings.tagline}</p>}
        {siteSettings.address && (
          <address class="mt-4 not-italic text-sm text-muted-foreground">
            {siteSettings.address.street && <span>{siteSettings.address.street}<br /></span>}
            {siteSettings.address.city}, {siteSettings.address.stateCode} {siteSettings.address.zip}
          </address>
        )}
        {siteSettings.phone && (
          <a href={`tel:${siteSettings.phone}`} class="block mt-2 text-sm font-medium">{siteSettings.phone}</a>
        )}
        {siteSettings.email && (
          <a href={`mailto:${siteSettings.email}`} class="block mt-1 text-sm text-muted-foreground">{siteSettings.email}</a>
        )}
      </div>

      {resolvedSections.map((section) => (
        <div>
          <p class="font-semibold mb-3">{section.heading}</p>
          <nav aria-label={`Footer navigation - ${section.heading}`}>
            <ul class="space-y-2 text-sm">
              {section.resolvedLinks.map((link: any) => (
                <li><a href={link.href} class="text-muted-foreground hover:text-foreground transition-colors">{link.label}</a></li>
              ))}
            </ul>
          </nav>
        </div>
      ))}

      <!-- Social links -->
      <div>
        {siteSettings.socialLinks && siteSettings.socialLinks.length > 0 && (
          <>
            <p class="font-semibold mb-3">Follow Us</p>
            <div class="flex gap-3">
              {siteSettings.socialLinks.map((social: any) => (
                <a href={social.url} target="_blank" rel="noopener noreferrer" class="text-muted-foreground hover:text-foreground transition-colors" aria-label={social.platform}>
                  {social.platform}
                </a>
              ))}
            </div>
          </>
        )}
      </div>
    </div>

    <div class="border-t mt-8 pt-8 text-center text-sm text-muted-foreground">
      <p>&copy; {currentYear} {siteSettings.siteName}. All rights reserved.</p>
      {siteSettings.footerText && <p class="mt-2">{siteSettings.footerText}</p>}
    </div>
  </div>
</footer>
