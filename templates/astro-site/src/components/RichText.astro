---
interface Props {
  content: any
  class?: string
}

const { content, class: className } = Astro.props

function escapeHtml(text: string): string {
  return text
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;')
}

const ALLOWED_PROTOCOLS = ['http:', 'https:', 'mailto:', 'tel:']

function isSafeUrl(url: string): boolean {
  try {
    const parsed = new URL(url, 'https://placeholder.invalid')
    return ALLOWED_PROTOCOLS.includes(parsed.protocol)
  } catch {
    return !url.startsWith('javascript:') && !url.startsWith('data:')
  }
}

function renderNode(node: any): string {
  if (!node) return ''

  switch (node.type) {
    case 'root': {
      return (node.children || []).map(renderNode).join('')
    }
    case 'paragraph': {
      const pContent = (node.children || []).map(renderNode).join('')
      return pContent ? '<p>' + pContent + '</p>' : ''
    }
    case 'heading': {
      const htag = 'h' + (node.tag || '2')
      return '<' + htag + '>' + (node.children || []).map(renderNode).join('') + '</' + htag + '>'
    }
    case 'text': {
      let text = escapeHtml(node.text || '')
      const fmt = node.format || 0
      if (fmt & 1) text = '<strong>' + text + '</strong>'
      if (fmt & 2) text = '<em>' + text + '</em>'
      if (fmt & 4) text = '<s>' + text + '</s>'
      if (fmt & 8) text = '<u>' + text + '</u>'
      if (fmt & 16) text = '<code>' + text + '</code>'
      if (fmt & 32) text = '<sub>' + text + '</sub>'
      if (fmt & 64) text = '<sup>' + text + '</sup>'
      return text
    }
    case 'link': {
      const href = (node.fields && node.fields.url) ? node.fields.url : '#'
      if (!isSafeUrl(href)) return (node.children || []).map(renderNode).join('')
      const target = (node.fields && node.fields.newTab) ? ' target="_blank" rel="noopener noreferrer"' : ''
      return '<a href="' + escapeHtml(href) + '"' + target + '>' + (node.children || []).map(renderNode).join('') + '</a>'
    }
    case 'list': {
      const ltag = node.listType === 'number' ? 'ol' : 'ul'
      return '<' + ltag + '>' + (node.children || []).map(renderNode).join('') + '</' + ltag + '>'
    }
    case 'listitem': {
      return '<li>' + (node.children || []).map(renderNode).join('') + '</li>'
    }
    case 'quote': {
      return '<blockquote>' + (node.children || []).map(renderNode).join('') + '</blockquote>'
    }
    case 'upload': {
      const img = node.value
      if (img && img.url) {
        const cap = img.caption ? '<figcaption>' + escapeHtml(img.caption) + '</figcaption>' : ''
        return '<figure><img src="' + escapeHtml(img.url) + '" alt="' + escapeHtml(img.alt || '') + '" loading="lazy" />' + cap + '</figure>'
      }
      return ''
    }
    default: {
      return (node.children || []).map(renderNode).join('')
    }
  }
}

const html = (content && content.root) ? renderNode(content.root) : ''
---

{html.length > 0 && <div class:list={['prose prose-lg max-w-none', className]} set:html={html} />}
