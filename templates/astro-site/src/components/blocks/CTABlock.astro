---
interface Props { data: any; context?: Record<string, any>; headingLevel?: 2 | 3 | 4 }
const { data, context = {}, headingLevel = 2 } = Astro.props
const HeadingTag = `h${headingLevel}` as any
---
<section class:list={['py-16 px-4', {
  'bg-primary text-primary-foreground': data.style === 'banner' || !data.style,
  'bg-muted': data.style === 'card',
}]}>
  <div class="container mx-auto text-center max-w-2xl">
    <HeadingTag class="text-3xl font-bold mb-4">{data.heading}</HeadingTag>
    {data.subheading && <p class="text-lg mb-8 opacity-90">{data.subheading}</p>}
    <div class="flex gap-4 justify-center flex-wrap">
      {data.buttonLink && (
        <a href={data.buttonLink} class="px-8 py-3 bg-background text-foreground rounded-lg font-semibold">
          {data.buttonText || 'Contact Us'}
        </a>
      )}
      {data.phone && (
        <a href={`tel:${data.phone}`} class="px-8 py-3 border border-current rounded-lg font-semibold">
          Call {data.phone}
        </a>
      )}
    </div>
  </div>
</section>
