---
interface Props { data: any; context?: Record<string, any>; headingLevel?: 2 | 3 | 4 }
const { data, context = {}, headingLevel = 2 } = Astro.props
const HeadingTag = `h${headingLevel}` as any
---
<section class="py-12 px-4" aria-label={data.heading || 'Location map'}>
  <div class="container mx-auto">
    {data.heading && <HeadingTag class="text-3xl font-bold mb-6">{data.heading}</HeadingTag>}
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {data.embedUrl && (
        <iframe src={data.embedUrl} width="100%" height="400" style="border:0" loading="lazy" allowfullscreen title="Service area map"></iframe>
      )}
      <div>
        {data.address && <p class="text-muted-foreground whitespace-pre-line">{data.address}</p>}
        {data.serviceRadius && <p class="mt-4 font-medium">Service Area: {data.serviceRadius}</p>}
      </div>
    </div>
  </div>
</section>
