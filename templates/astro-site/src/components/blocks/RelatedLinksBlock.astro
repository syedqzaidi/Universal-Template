---
interface Props { data: any; context?: Record<string, any>; headingLevel?: 2 | 3 | 4 }
const { data, context = {}, headingLevel = 2 } = Astro.props
const HeadingTag = `h${headingLevel}` as any
const links = data.links || []
const maxItems = data.maxItems || 6
---
<aside class="py-12 px-4 bg-muted/30">
  <div class="container mx-auto max-w-4xl">
    {data.heading && <HeadingTag class="text-2xl font-semibold mb-6">{data.heading}</HeadingTag>}
    <ul class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {links.slice(0, maxItems).map((link: any) => (
        <li>
          <a href={link.url} class="block border rounded-lg p-4 hover:bg-background hover:shadow-sm transition-all">
            <p class="font-medium text-primary">{link.title}</p>
            {link.description && <p class="text-sm text-muted-foreground mt-1">{link.description}</p>}
          </a>
        </li>
      ))}
    </ul>
  </div>
</aside>
