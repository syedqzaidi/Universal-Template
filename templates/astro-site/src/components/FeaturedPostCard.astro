---
import PayloadImage from './PayloadImage.astro'

interface Props {
  post: any
}

const { post } = Astro.props
const author = typeof post.author === 'object' ? post.author : null
const date = post.publishedAt ? new Date(post.publishedAt).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) : ''
---

<article class="relative grid grid-cols-1 md:grid-cols-2 gap-6 rounded-xl border bg-card overflow-hidden group">
  <div class="relative aspect-[4/3] overflow-hidden">
    {post.featuredImage && (
      <PayloadImage image={post.featuredImage} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
    )}
    <span class="absolute top-4 left-4 px-3 py-1 text-xs font-semibold rounded-full bg-primary text-primary-foreground">
      Featured
    </span>
  </div>
  <div class="flex flex-col justify-center p-5 md:p-8">
    {post.category && <span class="text-sm font-medium text-primary mb-2">{post.category}</span>}
    <h2 class="text-2xl md:text-3xl font-bold leading-tight mb-3">
      <a href={`/blog/${post.slug}`} class="hover:text-primary transition-colors after:absolute after:inset-0">
        {post.title}
      </a>
    </h2>
    {post.excerpt && <p class="text-muted-foreground line-clamp-3 mb-4">{post.excerpt}</p>}
    <div class="flex items-center gap-3 text-sm text-muted-foreground mt-auto">
      {author?.photo && typeof author.photo === 'object' && (
        <img src={author.photo.url} alt={author.name} class="w-8 h-8 rounded-full object-cover" />
      )}
      {author?.name && <span class="font-medium">{author.name}</span>}
      {date && <span>{date}</span>}
      {post.readTime && <span>{post.readTime} min read</span>}
    </div>
  </div>
</article>
